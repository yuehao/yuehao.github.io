---

<footer class="bg-surface-alt border-t border-default mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- About -->
      <div class="col-span-1 md:col-span-2">
        <h3 class="font-semibold text-lg mb-4">Beam Physics and Data-driven Methods in Particle Accelerators</h3>
        <p class="text-muted text-sm mb-4">
          <a href="https://frib.msu.edu/" class="hover:text-primary transition-colors">Facility for Rare Isotope Beams (FRIB)</a>,<br />
          <a href="https://www.msu.edu/" class="hover:text-primary transition-colors">Michigan State University</a>
        </p>
        <p class="text-muted text-sm">
          We always welcome new members to our group. If you are interested in our research, please feel free to contact us.
        </p>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold text-lg mb-4">Connect</h3>
        <div class="flex flex-wrap gap-3">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 rounded-lg text-muted hover:text-primary hover:bg-primary/5 transition-colors"
              aria-label={link.name}
              title={link.name}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d={link.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Bottom bar -->
    <div class="mt-8 pt-8 border-t border-default flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-muted">
        © {currentYear} Yue Hao. Built with <a href="https://astro.build" class="hover:text-primary transition-colors">Astro</a>.
      </p>
      <p class="text-sm text-muted">
        Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </div>
  </div>
</footer>
