---
interface Props {
  name: string;
  role: string;
  image?: string;
  bio?: string;
  website?: string;
  email?: string;
  linkedin?: string;
  scholar?: string;
  github?: string;
  orcid?: string;
  link?: string;
  isPrincipalInvestigator?: boolean;
  variant?: 'horizontal' | 'vertical';
}

const {
  name,
  role,
  image,
  bio,
  website,
  email,
  linkedin,
  scholar,
  github,
  orcid,
  link,
  isPrincipalInvestigator = false,
  variant = 'horizontal'
} = Astro.props;

const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();

// For non-PI members, use the provided link (usually LinkedIn) as the primary link for name/image
const primaryLink = link || (isPrincipalInvestigator ? website : undefined);

// Avatar dimensions: vertical (current members) is 20% larger than horizontal (alumni).
const avatarSize = variant === 'vertical' ? 'w-24 h-24' : 'w-20 h-20';
const initialsSize = variant === 'vertical' ? 'text-2xl' : 'text-xl';
---

<article class="group bg-surface rounded-xl border border-default overflow-hidden card-hover h-full flex flex-col">
  <div class="p-6 flex flex-col flex-grow">
    {variant === 'vertical' ? (
      <div class="flex flex-col flex-grow">
        <!-- Top row: headshot on the left, name + role on the right -->
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0">
            {primaryLink ? (
              <a href={primaryLink} target={primaryLink.startsWith('/') ? '_self' : '_blank'} rel="noopener noreferrer">
                {image ? (
                  <img
                    src={image}
                    alt={name}
                    class={`${avatarSize} rounded-xl object-cover ring-2 ring-primary/10 hover:ring-primary/30 transition-all`}
                  />
                ) : (
                  <div class={`${avatarSize} rounded-xl bg-primary/10 flex items-center justify-center text-primary font-bold ${initialsSize} hover:bg-primary/20 transition-colors`}>
                    {initials}
                  </div>
                )}
              </a>
            ) : (
              image ? (
                <img
                  src={image}
                  alt={name}
                  class={`${avatarSize} rounded-xl object-cover ring-2 ring-primary/10`}
                />
              ) : (
                <div class={`${avatarSize} rounded-xl bg-primary/10 flex items-center justify-center text-primary font-bold ${initialsSize}`}>
                  {initials}
                </div>
              )
            )}
          </div>

          <div class="flex-grow min-w-0 pt-1">
            <h3 class="font-semibold text-lg truncate group-hover:text-primary transition-colors">
              {primaryLink ? (
                <a href={primaryLink} target={primaryLink.startsWith('/') ? '_self' : '_blank'} rel="noopener noreferrer" class="hover:underline">
                  {name}
                </a>
              ) : (
                name
              )}
            </h3>
            <p class="text-sm text-accent font-medium">{role}</p>
          </div>
        </div>

        <!-- Bio spans full width below the headshot + name row -->
        {bio && (
          <p class="text-sm text-muted mt-3">{bio}</p>
        )}
      </div>
    ) : (
      <div class="flex items-start gap-4 flex-grow">
        <!-- Avatar -->
        <div class="flex-shrink-0">
          {primaryLink ? (
            <a href={primaryLink} target={primaryLink.startsWith('/') ? '_self' : '_blank'} rel="noopener noreferrer">
              {image ? (
                <img
                  src={image}
                  alt={name}
                  class={`${avatarSize} rounded-xl object-cover ring-2 ring-primary/10 hover:ring-primary/30 transition-all`}
                />
              ) : (
                <div class={`${avatarSize} rounded-xl bg-primary/10 flex items-center justify-center text-primary font-bold ${initialsSize} hover:bg-primary/20 transition-colors`}>
                  {initials}
                </div>
              )}
            </a>
          ) : (
            image ? (
              <img
                src={image}
                alt={name}
                class={`${avatarSize} rounded-xl object-cover ring-2 ring-primary/10`}
              />
            ) : (
              <div class={`${avatarSize} rounded-xl bg-primary/10 flex items-center justify-center text-primary font-bold ${initialsSize}`}>
                {initials}
              </div>
            )
          )}
        </div>

        <!-- Info -->
        <div class="flex-grow min-w-0">
          <h3 class="font-semibold text-lg truncate group-hover:text-primary transition-colors">
            {primaryLink ? (
              <a href={primaryLink} target={primaryLink.startsWith('/') ? '_self' : '_blank'} rel="noopener noreferrer" class="hover:underline">
                {name}
              </a>
            ) : (
              name
            )}
          </h3>
          <p class="text-sm text-accent font-medium">{role}</p>
          {bio && (
            <p class={`text-sm text-muted mt-2 ${isPrincipalInvestigator ? 'line-clamp-2' : ''}`}>{bio}</p>
          )}
        </div>
      </div>
    )}
    
    <!-- Social links - only show for PI with border, hide for others -->
    {isPrincipalInvestigator && (
      <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-default">
        {email && (
          <a
            href={`mailto:${email}`}
            class="p-2 rounded-lg text-muted hover:text-primary hover:bg-primary/5 transition-colors"
            aria-label="Email"
            title="Email"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        )}
        
        {isPrincipalInvestigator && linkedin && (
          <a
            href={linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-lg text-muted hover:text-primary hover:bg-primary/5 transition-colors"
            aria-label="LinkedIn"
            title="LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        )}
        
        {scholar && (
          <a
            href={scholar}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-lg text-muted hover:text-primary hover:bg-primary/5 transition-colors"
            aria-label="Google Scholar"
            title="Google Scholar"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
            </svg>
          </a>
        )}
        
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-lg text-muted hover:text-primary hover:bg-primary/5 transition-colors"
            aria-label="GitHub"
            title="GitHub"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>
        )}
        
        {orcid && (
          <a
            href={orcid}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-lg text-muted hover:text-primary hover:bg-primary/5 transition-colors"
            aria-label="ORCID"
            title="ORCID"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c.83 0 1.5.67 1.5 1.5S12.83 8 12 8s-1.5-.67-1.5-1.5S11.17 5 12 5zm3 12h-6v-1h2v-5h-2v-1h4v6h2v1z"/>
            </svg>
          </a>
        )}
        
        {isPrincipalInvestigator && website && (
          <a
            href={website}
            target={website.startsWith('/') ? '_self' : '_blank'}
            rel="noopener noreferrer"
            class="p-2 rounded-lg text-muted hover:text-primary hover:bg-primary/5 transition-colors"
            aria-label="Website"
            title="Website"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
      </div>
    )}
  </div>
</article>
