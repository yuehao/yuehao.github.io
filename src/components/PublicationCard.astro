---
interface Props {
  title: string;
  authors: string[];
  venue?: string;
  journal?: string;
  year: number;
  month?: string;
  doi?: string;
  pdf?: string;
  abstract?: string;
  arxiv?: string;
  bibtex?: string;
  selected?: boolean;
  key?: string;
  type?: string;
  volume?: string;
  pages?: string;
  preview?: string;
}

const { title, authors, venue, journal, year, month, doi, pdf, abstract, arxiv, bibtex, selected = false, preview } = Astro.props;

// Use venue or journal for display
const displayVenue = venue || journal || '';

// Format authors with "et al." if more than 4
function formatAuthors(authorList: string[]): string {
  if (authorList.length <= 4) {
    return authorList.join(', ');
  }
  return `${authorList.slice(0, 3).join(', ')}, and ${authorList.length - 3} more authors`;
}

const formattedAuthors = formatAuthors(authors);
const uniqueId = `pub-${title.replace(/\s+/g, '-').slice(0, 30)}`;
---

<article class="group bg-surface rounded-xl border border-default p-5 card-hover">
  <div class="flex gap-5">
    <!-- Preview Image -->
    {preview && (
      <div class="flex-shrink-0 w-40 h-28 rounded-lg overflow-hidden bg-muted/10">
        <img 
          src={preview} 
          alt={`Preview for ${title}`}
          class="w-full h-full object-cover"
        />
      </div>
    )}
    
    <div class="flex flex-col gap-3 flex-1">
    <!-- Title -->
    <h3 class="font-semibold text-lg leading-snug group-hover:text-primary transition-colors">
      {doi ? (
        <a href={`https://doi.org/${doi}`} target="_blank" rel="noopener noreferrer" class="hover:underline">
          {title}
        </a>
      ) : (
        title
      )}
      {selected && (
        <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-accent/10 text-accent">
          Selected
        </span>
      )}
    </h3>
    
    <!-- Authors -->
    <p class="text-sm text-muted">
      {formattedAuthors}
    </p>
    
    <!-- Venue and date -->
    <p class="text-sm">
      {displayVenue && <span class="italic">{displayVenue}</span>}
      {month && <span>, {month}</span>}
      <span> {year}</span>
    </p>
    
    <!-- Action buttons -->
    <div class="flex flex-wrap gap-2 mt-1">
      {pdf && (
        <a
          href={pdf}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors"
        >
          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          PDF
        </a>
      )}
      
      {doi && (
        <a
          href={`https://doi.org/${doi}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-lg bg-accent/10 text-accent hover:bg-accent/20 transition-colors"
        >
          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          DOI
        </a>
      )}
      
      {arxiv && (
        <a
          href={`https://arxiv.org/abs/${arxiv}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-lg bg-red-500/10 text-red-600 hover:bg-red-500/20 transition-colors"
        >
          arXiv
        </a>
      )}
      
      {abstract && (
        <button
          class="abstract-toggle inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-500/10 text-gray-600 hover:bg-gray-500/20 transition-colors dark:text-gray-400"
          data-target={uniqueId}
        >
          <svg class="w-3.5 h-3.5 mr-1.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
          Abstract
        </button>
      )}
      
      {bibtex && (
        <button
          class="cite-button inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-500/10 text-gray-600 hover:bg-gray-500/20 transition-colors dark:text-gray-400"
          data-bibtex={bibtex}
        >
          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          Cite
        </button>
      )}
    </div>
    
    <!-- Abstract (collapsible) -->
    {abstract && (
      <div id={uniqueId} class="hidden mt-3 p-4 bg-surface-alt rounded-lg text-sm text-muted leading-relaxed">
        {abstract}
      </div>
    )}
    </div>
  </div>
</article>

<script>
  // Abstract toggle
  document.querySelectorAll('.abstract-toggle').forEach(button => {
    button.addEventListener('click', () => {
      const targetId = button.getAttribute('data-target');
      const target = document.getElementById(targetId!);
      const icon = button.querySelector('svg');
      
      if (target) {
        target.classList.toggle('hidden');
        icon?.classList.toggle('rotate-180');
      }
    });
  });
  
  // Copy citation
  document.querySelectorAll('.cite-button').forEach(button => {
    button.addEventListener('click', async () => {
      const bibtex = button.getAttribute('data-bibtex');
      if (bibtex) {
        await navigator.clipboard.writeText(bibtex);
        const originalText = button.innerHTML;
        button.innerHTML = '<svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Copied!';
        setTimeout(() => {
          button.innerHTML = originalText;
        }, 2000);
      }
    });
  });
</script>
