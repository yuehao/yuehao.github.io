---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('people');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const p = entry.data;
---

<BaseLayout
  title={p.name}
  description={`${p.title ?? p.role} — ${p.name}`}
>
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Back link -->
      <div class="mb-8">
        <a href="/people" class="text-sm text-accent hover:underline">&larr; Back to People</a>
      </div>

      <div class="flex flex-col lg:flex-row gap-10">

        <!-- Sidebar -->
        <aside class="lg:w-72 shrink-0">
          <div class="sticky top-8">
            <div class="bg-surface-alt border border-default rounded-2xl overflow-hidden p-6 text-center">

              {p.image && (
                <img
                  src={p.image}
                  alt={p.name}
                  class="w-40 h-40 rounded-full object-cover mx-auto mb-4 border-4 border-white shadow"
                />
              )}

              <h1 class="text-2xl font-bold mb-1">{p.name}</h1>
              <p class="text-muted text-sm mb-4">{p.role}</p>

              <div class="text-left text-sm space-y-2 mt-4 border-t border-default pt-4">
                {p.title && (
                  <div>
                    <span class="font-semibold">Title</span>
                    <p class="text-muted">{p.title}</p>
                  </div>
                )}
                {p.address && (
                  <div>
                    <span class="font-semibold">Address</span>
                    <p class="text-muted whitespace-pre-line">{p.address}</p>
                  </div>
                )}
                {p.email && (
                  <div>
                    <span class="font-semibold">Email</span>
                    <p class="text-muted">{p.email}</p>
                  </div>
                )}
              </div>

              <!-- Social links -->
              {(p.website || p.github || p.scholar || p.orcid) && (
                <div class="flex justify-center gap-3 mt-5 pt-4 border-t border-default">
                  {p.website && (
                    <a href={p.website} target="_blank" rel="noopener noreferrer" title="Website"
                      class="text-muted hover:text-accent transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
                      </svg>
                    </a>
                  )}
                  {p.github && (
                    <a href={p.github} target="_blank" rel="noopener noreferrer" title="GitHub"
                      class="text-muted hover:text-accent transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                      </svg>
                    </a>
                  )}
                  {p.scholar && (
                    <a href={p.scholar} target="_blank" rel="noopener noreferrer" title="Google Scholar"
                      class="text-muted hover:text-accent transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/>
                      </svg>
                    </a>
                  )}
                  {p.orcid && (
                    <a href={p.orcid} target="_blank" rel="noopener noreferrer" title="ORCID"
                      class="text-muted hover:text-accent transition-colors font-bold text-xs flex items-center">
                      iD
                    </a>
                  )}
                </div>
              )}
            </div>
          </div>
        </aside>

        <!-- Main CV content -->
        <main class="flex-1 min-w-0 space-y-10">

          <!-- Research Interests -->
          {p.researchInterests && p.researchInterests.length > 0 && (
            <section>
              <h2 class="text-2xl font-bold border-b border-default pb-2 mb-6">Research Interests</h2>
              <div class="space-y-5">
                {p.researchInterests.map((ri) => (
                  <div>
                    <h3 class="font-semibold text-lg text-primary mb-1">{ri.topic}</h3>
                    <ul class="list-disc list-inside text-muted space-y-1 text-sm ml-2">
                      {ri.items.map((item) => <li>{item}</li>)}
                    </ul>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Education -->
          {p.education && p.education.length > 0 && (
            <section>
              <h2 class="text-2xl font-bold border-b border-default pb-2 mb-6">Education</h2>
              <div class="space-y-5">
                {p.education.map((edu) => (
                  <div class="flex gap-4">
                    <div class="w-16 shrink-0 text-muted text-sm font-mono pt-1">{edu.year}</div>
                    <div>
                      <h3 class="font-semibold">{edu.degree}</h3>
                      <p class="text-muted text-sm">{edu.institution}</p>
                      {edu.notes && edu.notes.length > 0 && (
                        <ul class="list-disc list-inside text-muted text-sm mt-1 ml-2 space-y-0.5">
                          {edu.notes.map((note) => <li>{note}</li>)}
                        </ul>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Working Experience -->
          {p.experience && p.experience.length > 0 && (
            <section>
              <h2 class="text-2xl font-bold border-b border-default pb-2 mb-6">Working Experience</h2>
              <div class="space-y-5">
                {p.experience.map((exp) => (
                  <div class="flex gap-4">
                    <div class="w-28 shrink-0 text-muted text-sm font-mono pt-1">{exp.period}</div>
                    <div>
                      <h3 class="font-semibold">{exp.position}</h3>
                      <p class="text-muted text-sm">{exp.organization}</p>
                      {exp.notes && exp.notes.length > 0 && (
                        <ul class="list-disc list-inside text-muted text-sm mt-1 ml-2">
                          {exp.notes.map((note) => <li>{note}</li>)}
                        </ul>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Synergy Activities -->
          {p.synergy && p.synergy.length > 0 && (
            <section>
              <h2 class="text-2xl font-bold border-b border-default pb-2 mb-6">Synergy Activities</h2>
              <div class="space-y-4">
                {p.synergy.map((s) => (
                  <div class="flex gap-4">
                    <div class="w-28 shrink-0 text-muted text-sm font-mono pt-0.5">{s.period}</div>
                    <div class="text-sm space-y-1">
                      {s.activity && <p>{s.activity}</p>}
                      {s.activities && s.activities.map((a) => <p>{a}</p>)}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Optional markdown body (bio, publications summary, etc.) -->
          <div class="prose prose-sm max-w-none dark:prose-invert">
            <Content />
          </div>

        </main>
      </div>
    </div>
  </section>
</BaseLayout>
