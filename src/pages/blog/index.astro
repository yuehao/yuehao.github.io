---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Blog posts data - will be moved to content collections
const posts = [
  {
    title: "Matrix workbook",
    slug: "matrix-workbook",
    date: "2024-06-06",
    description: "Notes on matrix methods in accelerator physics",
    tags: ["accelerator physics", "linear algebra", "beam dynamics"]
  }
];

const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<BaseLayout title="Blog" description="Latest posts from Hao Group on Beam Physics">
  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl font-bold mb-4">Blog</h1>
        <p class="text-muted">
          Notes, tutorials, and updates from our research group.
        </p>
      </div>
      
      <!-- Posts list -->
      <div class="space-y-8">
        {posts.map((post) => (
          <article class="bg-surface rounded-xl border border-default p-6 card-hover group">
            <time class="text-sm text-accent font-medium">
              {formatDate(post.date)}
            </time>
            
            <h2 class="text-xl font-semibold mt-2 mb-3 group-hover:text-primary transition-colors">
              <a href={`/blog/${post.slug}/`} class="hover:underline">
                {post.title}
              </a>
            </h2>
            
            <p class="text-muted mb-4">
              {post.description}
            </p>
            
            <div class="flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <span class="px-2 py-0.5 bg-surface-alt rounded text-xs text-muted">
                  {tag}
                </span>
              ))}
            </div>
            
            <a 
              href={`/blog/${post.slug}/`}
              class="inline-flex items-center mt-4 text-sm text-primary font-medium hover:underline"
            >
              Read more
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </article>
        ))}
      </div>
      
      {posts.length === 0 && (
        <div class="text-center py-16">
          <p class="text-muted">No posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
