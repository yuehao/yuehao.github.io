---

<BaseLayout title="People" description="Meet the team at Hao Group on Beam Physics">
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl font-bold mb-4">People</h1>
        <p class="text-muted">
          Meet our research group members, alumni, and collaborators.
        </p>
      </div>
      
      <!-- Current Members -->
      <section class="mb-16">
        <h2 class="text-2xl font-medium text-muted border-b border-default pb-2 mb-6 text-left">Current Members</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr">
          {currentMembers.map((person) => (
            <PersonCard
              {...person}
              variant="vertical"
              link={person.isPrincipalInvestigator ? undefined : person.linkedin}
            />
          ))}
        </div>
      </section>
      
      <!-- Alumni -->
      <section class="mb-16">
        <h2 class="text-2xl font-medium text-muted border-b border-default pb-2 mb-6 text-left">Alumni</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {alumni.map((person) => (
            <PersonCard 
              {...person} 
              link={person.linkedin}
            />
          ))}
        </div>
      </section>
      
      <!-- Undergraduate Researchers -->
      <section>
        <h2 class="text-2xl font-medium text-muted border-b border-default pb-2 mb-6 text-left">Undergraduate Researchers and Interns</h2>
        <div class="bg-surface rounded-xl border border-default overflow-hidden">
          <table class="w-full">
            <thead class="bg-surface-alt">
              <tr>
                <th class="text-left px-6 py-3 text-sm font-semibold">Name</th>
                <th class="text-left px-6 py-3 text-sm font-semibold hidden sm:table-cell">Affiliation</th>
                <th class="text-left px-6 py-3 text-sm font-semibold">Program</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-default">
              {undergrads.map((person) => (
                <tr class="hover:bg-surface-alt/50 transition-colors">
                  <td class="px-6 py-4">
                    {person.linkedin ? (
                      <a href={person.linkedin} target="_blank" rel="noopener noreferrer" class="font-medium hover:text-primary transition-colors">
                        {person.name}
                      </a>
                    ) : (
                      <span class="font-medium">{person.name}</span>
                    )}
                  </td>
                  <td class="px-6 py-4 text-muted hidden sm:table-cell">{person.affiliation}</td>
                  <td class="px-6 py-4 text-sm text-muted">{person.program}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
