---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Group by category, preserving insertion order
const projectCategories: Record<string, typeof allProjects> = {};
for (const entry of allProjects) {
  const cat = entry.data.category;
  if (!projectCategories[cat]) projectCategories[cat] = [];
  projectCategories[cat].push(entry);
}

const categories = Object.keys(projectCategories);
---

<BaseLayout title="Projects" description="Research projects at Hao Group on Beam Physics">
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl font-bold mb-4">Projects</h1>
        <p class="text-muted">
          A growing collection of research projects in beam physics, computation, and data-driven modeling.
        </p>
      </div>
      
      <!-- Category filter -->
      <div class="flex flex-wrap gap-2 mb-8">
        <button class="category-filter px-4 py-2 rounded-lg bg-primary text-white text-sm font-medium transition-colors" data-category="all">
          All Projects
        </button>
        {categories.map((category) => (
          <button 
            class="category-filter px-4 py-2 rounded-lg bg-surface-alt text-muted hover:bg-primary/10 hover:text-primary text-sm font-medium transition-colors"
            data-category={category}
          >
            {category}
          </button>
        ))}
      </div>
      
      <!-- Projects grid -->
      <div class="space-y-12">
        {categories.map((category) => (
          <section class="project-category" data-category={category}>
            <h2 class="text-2xl font-medium text-muted border-b border-default pb-2 mb-6 text-left">{category}</h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {projectCategories[category].map((entry) => (
                <ProjectCard
                  title={entry.data.title}
                  description={entry.data.description}
                  category={entry.data.category}
                  image={entry.data.image}
                  href={`/projects/${entry.slug}/`}
                  tags={entry.data.tags}
                />
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterButtons = document.querySelectorAll('.category-filter');
  const projectSections = document.querySelectorAll('.project-category');
  
  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const category = button.getAttribute('data-category');
      
      // Update button styles
      filterButtons.forEach(btn => {
        btn.classList.remove('bg-primary', 'text-white');
        btn.classList.add('bg-surface-alt', 'text-muted');
      });
      button.classList.remove('bg-surface-alt', 'text-muted');
      button.classList.add('bg-primary', 'text-white');
      
      // Filter sections
      projectSections.forEach(section => {
        if (category === 'all' || section.getAttribute('data-category') === category) {
          section.classList.remove('hidden');
        } else {
          section.classList.add('hidden');
        }
      });
    });
  });
</script>
