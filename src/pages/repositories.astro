---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getRepoStats, parseGitHubRepoUrl } from '../utils/github';

// Repository data. `stars` and `forks` are the fallback values used in dev
// mode and whenever the GitHub API can't be reached at build time.
const repositories = [
  {
    name: "JuTrack.jl",
    description: "A Julia package for auto-differentiable accelerator modeling and particle tracking. Enables advanced automatic differentiation for symplectic 6-D particle tracking.",
    language: "Julia",
    stars: 17,
    forks: 2,
    url: "https://github.com/MSU-Beam-Dynamics/JuTrack.jl",
    topics: ["accelerator-physics", "particle-tracking", "automatic-differentiation", "julia"]
  },
  {
    name: "TrackPad.jl",
    description: "A Julia package for auto-differentiable accelerator tracking based on JuTrack.jl, integrated with machine learning models.",
    language: "Julia",
    stars: 0,
    forks: 0,
    url: "https://github.com/MSU-Beam-Dynamics/TrackPad.jl",
    topics: ["accelerator-physics", "particle-tracking", "automatic-differentiation", "julia", "machine-learning"]
  },
  {
    name: "PolySeries.jl",
    description: "A Julia package that provides a library for performing Truncated Power Series Algebra (TPSA). Supports both float and complex number derivatives.",
    language: "Julia",
    stars: 1,
    forks: 0,
    url: "https://github.com/MSU-Beam-Dynamics/PolySeries.jl",
    topics: ["TPSA", "accelerator-physics", "julia"]
  },
  {
    name: "PyTPSA",
    description: "A Python/C++ package that provides a library for performing Truncated Power Series Algebra (TPSA). Supports both float and complex number derivatives.",
    language: "C++/Python",
    stars: 1,
    forks: 0,
    url: "https://github.com/MSU-Beam-Dynamics/PyTPSA",
    topics: ["TPSA", "accelerator-physics", "python", "cython"]
  },
  {
    name: "SympNetsTorch",
    description: "Symplectic network modules for PyTorch. Implementation of symplectic neural network layers for identifying Hamiltonian systems.",
    language: "Python",
    stars: 0,
    forks: 0,
    url: "https://github.com/MSU-Beam-Dynamics/SympNetsTorch",
    topics: ["symplectic-networks", "pytorch", "machine-learning", "hamiltonian"]
  }
];

// At build time only, refresh stars/forks from the GitHub API. The dev
// server keeps the static values for a snappier experience.
const liveFetch = import.meta.env.PROD;
let lastFetched: Date | null = null;
const repos = await Promise.all(
  repositories.map(async (repo) => {
    if (liveFetch) {
      const parsed = parseGitHubRepoUrl(repo.url);
      if (parsed) {
        const stats = await getRepoStats(parsed.owner, parsed.repo, {
          stars: repo.stars,
          forks: repo.forks
        });
        lastFetched = new Date();
        return { ...repo, stars: stats.stars, forks: stats.forks };
      }
    }
    return repo;
  })
);

const languageColors: Record<string, string> = {
  "Julia": "bg-purple-500",
  "Python": "bg-blue-500",
  "JavaScript": "bg-yellow-500",
  "TypeScript": "bg-blue-600",
  "C++/Python": "bg-pink-500",
  "Fortran": "bg-green-600"
};
---

<BaseLayout title="Repositories" description="Open source repositories from Hao Group">
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl font-bold mb-4">Repositories</h1>
        <p class="text-muted">
          Open source code and tools developed by our research group.
        </p>
        <a 
          href="https://github.com/MSU-Beam-Dynamics" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center mt-4 text-accent hover:underline"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          View all on GitHub
        </a>
      </div>
      
      <!-- Repositories Grid -->
      <div class="grid md:grid-cols-2 gap-6">
        {repos.map((repo) => (
          <article class="bg-surface rounded-xl border border-default p-6 card-hover group">
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-semibold text-lg group-hover:text-primary transition-colors">
                <a href={repo.url} target="_blank" rel="noopener noreferrer" class="hover:underline flex items-center">
                  <svg class="w-5 h-5 mr-2 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                  </svg>
                  {repo.name}
                </a>
              </h3>
              <a 
                href={repo.url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-muted hover:text-primary transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
            
            <p class="text-sm text-muted mb-4 leading-relaxed">
              {repo.description}
            </p>
            
            <!-- Topics -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {repo.topics.map((topic) => (
                <span class="px-2 py-0.5 bg-accent/10 text-accent rounded text-xs">
                  {topic}
                </span>
              ))}
            </div>
            
            <!-- Stats -->
            <div class="flex items-center gap-4 text-sm text-muted">
              <span class="flex items-center">
                <span class={`w-3 h-3 rounded-full ${languageColors[repo.language] || 'bg-gray-500'} mr-1.5`}></span>
                {repo.language}
              </span>
              <span class="flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
                {repo.stars}
              </span>
              <span class="flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                </svg>
                {repo.forks}
              </span>
            </div>
          </article>
        ))}
      </div>
      
      <!-- Note about more repos -->
      <div class="mt-8 p-6 bg-surface-alt rounded-xl text-center">
        <p class="text-muted">
          More repositories and code examples are available on our
          <a href="https://github.com/yuehao" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">GitHub profile</a>.
        </p>
        {lastFetched && (
          <p class="text-xs text-muted mt-2">
            Star/fork counts refreshed from GitHub on {lastFetched.toISOString().slice(0, 10)}.
          </p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
